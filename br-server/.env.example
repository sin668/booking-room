# =============================================================================
# Booking Room Server - Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/booking_room

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (生成密钥: openssl rand -hex 32)
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Aliyun SMS
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=去K书
ALIYUN_SMS_TEMPLATE_CODE=SMS_504980114
ALIYUN_CAPTCHA_SCENE_ID=

# Admin
ADMIN_TOKEN=

# Booking verification
# Public H5 base URL used in QR code verify_url, e.g. https://booking.example.com
FRONTEND_BASE_URL=
BOOKING_TIMEZONE=Asia/Shanghai

# WeChat Pay
# Keep disabled for local development unless all merchant settings are provided.
WECHAT_PAY_ENABLED=false
WECHAT_PAY_APPID=
WECHAT_PAY_MCHID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_CERT_SERIAL_NO=
WECHAT_PAY_PLATFORM_CERT_SERIAL_NO=
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PATH=
WECHAT_PAY_NOTIFY_URL=
WECHAT_PAY_API_BASE_URL=https://api.mch.weixin.qq.com

# Cookie (生产环境设为 true)
COOKIE_SECURE=false

# Feature flags
REGISTRATION_ENABLED=true
