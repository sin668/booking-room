# =============================================================================
# Booking Room Server - Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/booking_room

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (生成密钥: openssl rand -hex 32)
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Aliyun SMS
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=去K书
ALIYUN_SMS_TEMPLATE_CODE=SMS_504980114
ALIYUN_CAPTCHA_SCENE_ID=

# Cookie (生产环境设为 true)
COOKIE_SECURE=false

# Feature flags
REGISTRATION_ENABLED=true
